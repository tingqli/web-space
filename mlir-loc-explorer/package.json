{
  "name": "mlir-loc-explorer",
  "displayName": "MLIR Loc Explorer",
  "description": "Side-by-side MLIR IR viewer with loc-based cross-file linking",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mlirLocExplorer.open",
        "title": "MLIR: Open Loc Explorer (Select Directory)"
      },
      {
        "command": "mlirLocExplorer.openFolder",
        "title": "MLIR: Open Loc Explorer Here"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mlirLocExplorer.openFolder",
          "when": "explorerResourceIsFolder && resourceScheme == file",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.9.5"
  }
}
